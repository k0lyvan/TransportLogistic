@model IEnumerable<TransportLogistic.Models.Route>

@{
    ViewData["Title"] = "Маршруты";
}

<h1>Управление маршрутами</h1>

@if (User.IsInRole("Admin") || User.IsInRole("Dispatcher"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Добавить маршрут</a>
    </p>
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Название маршрута</th>
            <th>Откуда</th>
            <th>Куда</th>
            <th>Расстояние (км)</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.StartNavigation.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.StopNavigation.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Distance) км</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a>

                    @if (User.IsInRole("Admin") || User.IsInRole("Dispatcher"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Ред.</a>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Уд.</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Нет добавленных маршрутов.
    </div>
}