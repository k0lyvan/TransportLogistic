@model TransportLogistic.Models.Route

@{
    ViewData["Title"] = "Добавить маршрут";
}

<h1>Добавить маршрут</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label">Название маршрута</label>
                <input asp-for="Name" class="form-control" placeholder="Например: Москва - Санкт-Петербург" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Start" class="control-label">Откуда (город)</label>
                <select asp-for="Start" class="form-control" asp-items="ViewBag.Cities">
                    <option value="">-- Выберите город --</option>
                </select>
                <span asp-validation-for="Start" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Stop" class="control-label">Куда (город)</label>
                <select asp-for="Stop" class="form-control" asp-items="ViewBag.Cities">
                    <option value="">-- Выберите город --</option>
                </select>
                <span asp-validation-for="Stop" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Distance" class="control-label">Расстояние (км)</label>
                <input asp-for="Distance" class="form-control" type="number" min="1" placeholder="Например: 705" />
                <span asp-validation-for="Distance" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Добавить" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}