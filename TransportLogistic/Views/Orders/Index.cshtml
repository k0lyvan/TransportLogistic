@using Microsoft.AspNetCore.Identity
@model IEnumerable<TransportLogistic.Models.Order>

@{
    ViewData["Title"] = "Заказы";
    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
}

<h1>Заказы</h1>

@if (User.Identity.IsAuthenticated && !User.IsInRole("Driver") && !User.IsInRole("Conductor"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Создать новый заказ</a>
    </p>
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Маршрут</th>
            <th>Дата отправления</th>
            <th>Место</th>
            <th>Цена</th>
            <th>Статус</th>
            <th>Пассажир</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TripNavigation?.RouteNavigation?.Name</td>
                <td>@item.TripNavigation?.DepatureTime.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@item.SeatNumber</td>
                <td>@item.Price.ToString("C")</td>
                <td>
                    @if (item.Stasus == "Ожидает подтверждения")
                    {
                        <span class="badge bg-warning">@item.Stasus</span>
                    }
                    else if (item.Stasus == "Подтвержден")
                    {
                        <span class="badge bg-success">@item.Stasus</span>
                    }
                    else if (item.Stasus == "Отменен")
                    {
                        <span class="badge bg-danger">@item.Stasus</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@item.Stasus</span>
                    }
                 </td>
                <td>@item.UserNavigation?.UserName ?? item.User</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a>
                    
                    @if (User.IsInRole("Admin") || User.IsInRole("Dispatcher"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Ред.</a>
                    }
                    
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Уд.</a>
                    }
                 </td>
             </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Нет заказов.
    </div>
}