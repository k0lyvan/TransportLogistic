@model IEnumerable<TransportLogistic.Models.Trip>

@{
    ViewData["Title"] = "Рейсы";
}

<h1>Управление рейсами</h1>

@if (User.IsInRole("Admin") || User.IsInRole("Dispatcher"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Создать новый рейс</a>
    </p>
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Маршрут</th>
            <th>Время отправления</th>
            <th>Время прибытия</th>
            <th>Транспорт</th>
            <th>Водитель</th>
            <th>Кондуктор</th>
            <th>Цена (₽)</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.RouteNavigation?.Name</td>
                <td>@item.DepatureTime.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@item.ArrivalTime.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@item.TransportNavigation?.Model - @item.TransportNavigation?.CarNumber</td>
                <td>@(item.DriverNavigation?.UserName ?? item.Driver ?? "Не назначен")</td>
                <td>@(item.ConductorNavigation?.UserName ?? item.Conductor ?? "Не назначен")</td>
                <td>@item.Price.ToString("N0") ₽</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a>

                    @if (User.IsInRole("Admin") || User.IsInRole("Dispatcher"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Ред.</a>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Уд.</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Нет доступных рейсов.
    </div>
}