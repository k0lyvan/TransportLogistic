@model TransportLogistic.Models.Trip

@{
    ViewData["Title"] = "Детали рейса";
}

<h1>Детали рейса</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Маршрут
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.RouteNavigation.Name)
        </dd>

        <dt class="col-sm-2">
            Откуда
        </dt>
        <dd class="col-sm-10">
            @if (Model.RouteNavigation?.StartNavigation != null)
            {
                @Html.DisplayFor(model => model.RouteNavigation.StartNavigation.Name)
            }
            else
            {
                <span class="text-muted">Не указано</span>
            }
        </dd>

        <dt class="col-sm-2">
            Куда
        </dt>
        <dd class="col-sm-10">
            @if (Model.RouteNavigation?.StopNavigation != null)
            {
                @Html.DisplayFor(model => model.RouteNavigation.StopNavigation.Name)
            }
            else
            {
                <span class="text-muted">Не указано</span>
            }
        </dd>

        <dt class="col-sm-2">
            Расстояние
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.RouteNavigation.Distance) км
        </dd>

        <dt class="col-sm-2">
            Время отправления
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DepatureTime)
        </dd>

        <dt class="col-sm-2">
            Время прибытия
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ArrivalTime)
        </dd>

        <dt class="col-sm-2">
            Транспорт
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TransportNavigation.Model) - @Html.DisplayFor(model => model.TransportNavigation.CarNumber)
        </dd>

        <dt class="col-sm-2">
            Вместимость
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TransportNavigation.Capacity) мест
        </dd>

        <dt class="col-sm-2">
            Водитель
        </dt>
        <dd class="col-sm-10">
            @if (Model.DriverNavigation != null)
            {
                @Html.DisplayFor(model => model.DriverNavigation.UserName)
            }
            else
            {
                <span class="text-muted">Не назначен</span>
            }
        </dd>

        <dt class="col-sm-2">
            Кондуктор
        </dt>
        <dd class="col-sm-10">
            @if (Model.ConductorNavigation != null)
            {
                @Html.DisplayFor(model => model.ConductorNavigation.UserName)
            }
            else
            {
                <span class="text-muted">Не назначен</span>
            }
        </dd>
        <dt class="col-sm-2">Цена билета</dt>
        <dd class="col-sm-10">@Model.Price.ToString("N0") ₽</dd>
        <dt class="col-sm-2">
            Статус
        </dt>
        <dd class="col-sm-10">
            @if (Model.DepatureTime > DateTime.Now)
            {
                <span class="badge bg-success">Предстоящий</span>
            }
            else if (Model.ArrivalTime < DateTime.Now)
            {
                <span class="badge bg-secondary">Завершен</span>
            }
            else
            {
                <span class="badge bg-warning">В пути</span>
            }
        </dd>
    </dl>
</div>
<div>
    @if (User.IsInRole("Admin") || User.IsInRole("Dispatcher"))
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Редактировать</a>
        <span> </span>
    }
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger">Удалить</a>
        <span> </span>
    }
    <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
</div>