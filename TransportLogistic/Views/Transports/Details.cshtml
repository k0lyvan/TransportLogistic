@model TransportLogistic.Models.Transport

@{
    ViewData["Title"] = "Детали транспорта";
}

<h1>Детали транспорта</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Модель
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Model)
        </dd>

        <dt class="col-sm-2">
            Государственный номер
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CarNumber)
        </dd>

        <dt class="col-sm-2">
            Вместимость
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Capacity) мест
        </dd>
    </dl>
</div>
<div>
    @if (User.IsInRole("Admin") || User.IsInRole("Dispatcher"))
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Редактировать</a>
        <span> </span>
    }
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger">Удалить</a>
        <span> </span>
    }
    <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
</div>