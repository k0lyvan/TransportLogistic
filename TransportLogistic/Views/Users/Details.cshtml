@using Microsoft.AspNetCore.Identity
@model IdentityUser

@{
    ViewData["Title"] = "Детали пользователя";
    var roles = ViewBag.Roles as List<string>;
}

<h1>Детали пользователя</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Id
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Id)
        </dd>

        <dt class="col-sm-2">
            Email
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Email)
        </dd>

        <dt class="col-sm-2">
            Имя пользователя
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UserName)
        </dd>

        <dt class="col-sm-2">
            Роли
        </dt>
        <dd class="col-sm-10">
            @if (roles != null && roles.Any())
            {
                @string.Join(", ", roles)
            }
            else
            {
                <span class="text-muted">Нет ролей</span>
            }
        </dd>

        <dt class="col-sm-2">
            Email подтвержден
        </dt>
        <dd class="col-sm-10">
            @(Model.EmailConfirmed ? "Да" : "Нет")
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Редактировать</a>
    <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
</div>